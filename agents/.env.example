# Agent wallet — owns iNFTs, signs viem txs (deliverBounty, settleBounty, ENS)
AGENT_PRIVATE_KEY=

# Separate wallet for ALL 0G Storage uploads (appendLog/putKV).
# Using a different wallet here removes nonce contention with the agent
# wallet's viem-signed txs. Just needs ~1 OG on 0G testnet for storage fees.
OG_STORAGE_PK=

# 0G Compute (filled in by `npm run bootstrap:compute`)
OG_COMPUTE_PROVIDER=0xa48f01287233509FD694a22Bf840225062E67836
OG_MODEL=qwen/qwen-2.5-7b-instruct

# (optional) override 0G Storage endpoints — defaults are fine for testnet
# OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
# OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
# OG_STORAGE_KV_NODE=http://3.101.147.150:6789
